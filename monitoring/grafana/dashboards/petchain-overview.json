{
  "title": "PetChain - Performance Overview",
  "uid": "petchain-overview",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (method, route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{ method }} {{ route }}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, method, route) (rate(http_request_duration_ms_bucket[5m])))",
          "legendFormat": "{{ method }} {{ route }}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_errors_total[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
          "legendFormat": "global error rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "http_active_requests",
          "legendFormat": "in flight"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "process_cpu_usage_percent",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 6,
      "title": "Heap Utilization (%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "100 * process_heap_utilization_ratio",
          "legendFormat": "heap used"
        }
      ]
    },
    {
      "id": 7,
      "title": "Event Loop Lag (ms)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "process_event_loop_lag_ms",
          "legendFormat": "lag"
        }
      ]
    },
    {
      "id": 8,
      "title": "Active Alerts",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(alerts_fired_total)",
          "legendFormat": "alerts"
        }
      ]
    },
    {
      "id": 9,
      "title": "Resident Memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "rss"
        }
      ]
    },
    {
      "id": 10,
      "title": "Top Busy Routes",
      "type": "table",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "topk(5, sum by (method, route) (rate(http_requests_total[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{ method }} {{ route }}"
        }
      ]
    }
  ]
}
