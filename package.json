{
  "name": "pet-medical-tracka",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "type-check": "npx tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "clean": "rm -rf .next",
    "clean:all": "rm -rf .next node_modules",
    "audit:fix": "npm audit fix --omit=dev || true",
    "test": "npm run test:password && npm run test:debug",
    "test:password": "npx ts-node --project tsconfig.test.json src/utils/passwordPolicy.test.ts",
    "test:debug": "npx ts-node --project tsconfig.test.json tests/debug.test.ts",
    "security:audit": "npm audit --omit=dev --audit-level=critical || true",
    "debug": "NODE_OPTIONS='--inspect' next dev",
    "analyze": "ANALYZE=true next build",
    "perf:smoke": "bash ./performance/scripts/run-k6.sh smoke",
    "perf:load": "bash ./performance/scripts/run-k6.sh load",
    "perf:benchmark": "node ./performance/scripts/benchmark-report.mjs ./performance/results/load-summary.json",
    "perf:compare": "node ./performance/scripts/compare-baseline.mjs ./performance/results/load-summary.json ./performance/baselines/load-summary-baseline.json 0.15",
    "perf:refresh-baseline": "cp ./performance/results/load-summary.json ./performance/baselines/load-summary-baseline.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@stellar/stellar-sdk": "^14.4.3",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "axios": "^1.15.0",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.4",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "web-vitals": "^5.3.0",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.3.4",
    "@next/bundle-analyzer": "^15.3.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.2.0",
    "prettier": "^3.9.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
