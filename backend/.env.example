# Copy this file to .env and fill in all required values before starting the server.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/petchain

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string

# ── API Key Hashing (REQUIRED) ────────────────────────────────────────────────
# Used as the scrypt salt when hashing stored API keys.
# Must be set or the server will refuse to start.
# Generate a value with: openssl rand -hex 32
API_KEY_HMAC_SECRET=replace-with-a-long-random-string

# ── Redis / Cache ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BUCKET=petchain-uploads
